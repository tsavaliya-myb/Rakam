NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Runtime queries go through PgBouncer (transaction pool). pgbouncer=true disables
# Prisma's prepared statements, which are incompatible with transaction pooling.
DATABASE_URL=postgresql://rakam:rakam@localhost:6432/rakam?schema=public&pgbouncer=true
# Migrations / introspection bypass PgBouncer and hit Postgres directly.
DIRECT_URL=postgresql://rakam:rakam@localhost:5432/rakam?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_TTL=30d

MSG91_AUTH_KEY=
MSG91_WIDGET_ID=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

GSP_PROVIDER=masters_india
GSP_BASE_URL=
GSP_CLIENT_ID=
GSP_CLIENT_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
